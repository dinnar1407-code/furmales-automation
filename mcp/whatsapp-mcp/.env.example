# FurMates WhatsApp MCP — Environment Variables
# Get from: https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# API rate limits (Twilio WhatsApp):
# - 80 messages/second per number (production)
# - 1 message/second (sandbox)
# - Template messages required for business-initiated conversations
